# Copy this file to ".env" and fill in your Kite Connect credentials.
# Get these from the Kite developer console: https://developers.kite.trade/apps

KITE_API_KEY=your_api_key_here
KITE_API_SECRET=your_api_secret_here

# Port this backend listens on.
PORT=3001

# Where the frontend runs (used for CORS + post-login redirect).
# NOTE: Use 127.0.0.1 (not localhost) so it matches the Kite Redirect URL.
FRONTEND_URL=http://127.0.0.1:5173

# IMPORTANT: In the Kite developer console, set your app's
# "Redirect URL" to your frontend verify route. Kite requires HTTPS, but
# allows a http://127.0.0.1 URL for local testing (localhost is NOT allowed
# unless you serve the frontend over HTTPS). Use exactly:
#   http://127.0.0.1:5173/zerodha/verify
# and browse your app at http://127.0.0.1:5173 (not http://localhost:5173).

# Full-admin secret - required for /admin/verify (Zerodha login + trades + all).
ADMIN_SECRET=your_secret_key_here

# Trade-access password - required for /admin/access (view & take trades only,
# NO Zerodha login controls). Shares the same trades as the full admin.
ACCESS_SECRET=your_trade_access_password_here

# MongoDB connection string (Mongoose) for persisting calendar-spread trades.
# Include the database name in the URI itself, e.g.
#   mongodb+srv://user:pass@cluster.mongodb.net/calspread?retryWrites=true&w=majority
# If left blank, the trades feature is disabled (the rest of the app still works).
MONGODB_URI=

# MongoDB connection string for the nse_fno ARCHIVE database (read-only).
# Contains historical stock_futures data up to Aug 31, 2025 (fnodata1 cluster).
# Example: mongodb+srv://user:pass@fnodata1.mongodb.net/nse_fno?retryWrites=true&w=majority
# If left blank, historical spread computation for pre-2026 dates is disabled.
NSE_FNO_ARCHIVE_URI=

# MongoDB connection string for the nse_fno CURRENT database (read-write).
# Contains stock_futures data from Jan 1, 2026 onwards (fnodata2 cluster).
# This is where new daily F&O closing data is written by the EOD scheduler.
# Example: mongodb+srv://user:pass@fnodata2.mongodb.net/nse_fno?retryWrites=true&w=majority
# If left blank, EOD stock_futures capture is disabled.
NSE_FNO_CURRENT_URI=

# MongoDB connection string for the spread database (read-write).
# Contains spread_daily and spread_summary collections (calspread cluster).
# Example: mongodb+srv://user:pass@calspread.mongodb.net/calspread?retryWrites=true&w=majority
# If left blank, spread computation and summary are disabled.
NSE_FNO_SPREAD_URI=
